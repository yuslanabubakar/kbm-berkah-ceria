{
  "name": "kbm-berkah-ceria",
  "version": "0.1.0",
  "private": true,
  "description": "KBM Berkah Ceria - aplikasi berbagi biaya perjalanan berbasis Next.js dan Supabase",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "next build && npx @cloudflare/next-on-pages",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "prettier:write": "cross-env PRETTIER_NO_GLOB=1 prettier --ignore-unknown --no-error-on-unmatched-pattern --write",
    "typecheck": "tsc --noEmit",
    "prepare": "husky install"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "2.86.0",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "next": "14.2.35",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.4.0",
    "@types/node": "20.14.7",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "cross-env": "7.0.3",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.4",
    "eslint-plugin-prettier": "5.1.3",
    "husky": "9.0.11",
    "lint-staged": "15.2.2",
    "postcss": "8.4.38",
    "prettier": "3.3.2",
    "tailwindcss": "3.4.4",
    "typescript": "5.4.5",
    "wrangler": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "next lint --fix --file"
    ],
    "*.{ts,tsx,js,jsx,css,md,mdx,json}": [
      "pnpm run prettier:write --"
    ]
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
